# Stripe secret key (from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_your_secret_key_here

# Stripe webhook signing secret (from https://dashboard.stripe.com/webhooks)
# Required for /stripe/webhook to verify Stripe signatures.
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Allowed CORS origins — comma-separated list of frontend URLs
# For GitHub Pages: https://elitedigitalconsulting.github.io
# For local dev:    http://localhost:3000
# Include the admin UI origin if hosted separately
CLIENT_ORIGINS=http://localhost:3000

# Port the server listens on (default: 4000)
PORT=4000

# ---------------------------------------------------------------------------
# Email (SMTP) — used for stockist applications AND order notifications
# ---------------------------------------------------------------------------
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=noreply@neurotonics.com.au

# ---------------------------------------------------------------------------
# CMS Authentication
# ---------------------------------------------------------------------------
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
CMS_JWT_SECRET=change-me-access-secret-min-32-chars
CMS_JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars

# ---------------------------------------------------------------------------
# Initial admin user (created on first server start if no users exist)
# ---------------------------------------------------------------------------
ADMIN_INITIAL_EMAIL=admin@neurotonics.com.au
ADMIN_INITIAL_PASSWORD=changeme-set-a-strong-password

# ---------------------------------------------------------------------------
# GitHub Actions rebuild trigger
# Create a PAT at https://github.com/settings/tokens with 'repo' scope
# ---------------------------------------------------------------------------
GITHUB_PAT=ghp_your_personal_access_token
GITHUB_OWNER=elitedigitalconsulting
GITHUB_REPO=neurotonics

# ---------------------------------------------------------------------------
# SQLite database path (default: server/data/neurotonics.db)
# ---------------------------------------------------------------------------
# DB_PATH=/absolute/path/to/neurotonics.db

