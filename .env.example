# ---------------------------------------------------------------------------
# Stockist Application Form (Web3Forms)
# Web3Forms sends the stockist application form submission by email — no
# backend server required. It works directly from the browser on GitHub Pages.
#
# Steps:
#   1. Go to https://web3forms.com/
#   2. Enter admin@elitedigitalconsulting.com.au and click "Create your Access Key"
#   3. Copy the access key and paste it below
#   4. Add NEXT_PUBLIC_WEB3FORMS_KEY as a GitHub repository secret so it is
#      available at build time (Settings → Secrets → Actions → New secret)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_WEB3FORMS_KEY=your-web3forms-access-key

# ---------------------------------------------------------------------------
# Checkout Backend URL (legacy / optional)
# Only needed if you are running the standalone Express server in server/.
# Leave blank if using Web3Forms for the stockist form (recommended).
# ---------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=

# ---------------------------------------------------------------------------
# Email (for stockist application form)
# The server uses nodemailer to forward stockist applications to the admin.
# Configure your SMTP provider below.
#
# Gmail example (use an App Password, not your account password):
#   EMAIL_HOST=smtp.gmail.com
#   EMAIL_PORT=587
#   EMAIL_SECURE=false   (STARTTLS on port 587)
#   EMAIL_USER=your-address@gmail.com
#   EMAIL_PASS=your-app-password
#
# Sending-domain / from address:
#   EMAIL_FROM=noreply@neurotonics.com.au
#
# Destination address for stockist applications:
#   STOCKIST_EMAIL=admin@elitedigitalconsulting.com.au
# ---------------------------------------------------------------------------
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-smtp-user@example.com
EMAIL_PASS=your-smtp-password-or-app-password
EMAIL_FROM=noreply@neurotonics.com.au
STOCKIST_EMAIL=admin@elitedigitalconsulting.com.au

# ---------------------------------------------------------------------------
# Stripe Keys
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY  — frontend publishable key (safe to expose)
# STRIPE_SECRET_KEY                   — server secret key (never expose to browser)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=

# ---------------------------------------------------------------------------
# Amazon Location Service — address autocomplete (checkout page)
#
# NEXT_PUBLIC_AWS_LOCATION_API_KEY   — API key created in the AWS Console
#   (Amazon Location Service → API keys → Create API key).
#   Grant the action geo-places:Autocomplete and restrict to your domain.
#   https://console.aws.amazon.com/location/api-keys
#
# NEXT_PUBLIC_AWS_LOCATION_REGION    — AWS region for the Places endpoint.
#   Default: ap-southeast-2 (Sydney). Change only if your API key was
#   created in a different region.
#
# Leave NEXT_PUBLIC_AWS_LOCATION_API_KEY blank to disable autocomplete
# (manual address entry will be used instead).
# ---------------------------------------------------------------------------
NEXT_PUBLIC_AWS_LOCATION_API_KEY=
NEXT_PUBLIC_AWS_LOCATION_REGION=ap-southeast-2
