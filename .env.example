# ---------------------------------------------------------------------------
# Checkout Backend URL
# Point this at your deployed Express server (see server/ directory).
# For local development:  http://localhost:4000
# For production:         https://your-server.onrender.com  (or Railway, etc.)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:4000

# ---------------------------------------------------------------------------
# Email (for stockist application form)
# The server uses nodemailer to forward stockist applications to the admin.
# Configure your SMTP provider below.
#
# Gmail example (use an App Password, not your account password):
#   EMAIL_HOST=smtp.gmail.com
#   EMAIL_PORT=587
#   EMAIL_SECURE=false   (STARTTLS on port 587)
#   EMAIL_USER=your-address@gmail.com
#   EMAIL_PASS=your-app-password
#
# Sending-domain / from address:
#   EMAIL_FROM=noreply@neurotonics.com.au
#
# Destination address for stockist applications:
#   STOCKIST_EMAIL=admin@elitedigitalconsulting.com.au
# ---------------------------------------------------------------------------
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-smtp-user@example.com
EMAIL_PASS=your-smtp-password-or-app-password
EMAIL_FROM=noreply@neurotonics.com.au
STOCKIST_EMAIL=admin@elitedigitalconsulting.com.au

# ---------------------------------------------------------------------------
# Stripe Keys (only needed if you still use the legacy /api routes locally)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
